# Root .gitignore for CloudCost Project

# Environment Variables (CRITICAL - Contains AWS keys!)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# AWS credentials
.aws/
*.pem
*.ppk
cloudcost-key.pem

# Database
*.sqlite
*.db

# Temporary files
tmp/
temp/
*.tmp

# Coverage reports
coverage/
.nyc_output/

# Documentation (optional - remove if you want to include)
# MULTI_USER_SETUP.md
# DUMMY_USERS.md
# AUTH_FLOW.md
# IMPLEMENTATION_SUMMARY.md
# AWS_INTEGRATION_GUIDE.md
# AWS_SETUP_FOR_BEGINNERS.md
# AWS_QUICK_REFERENCE.md
USER_CREDENTIALS.txt

# Lock files (optional - some prefer to include these)
# package-lock.json
# yarn.lock
